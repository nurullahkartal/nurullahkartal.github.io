---
import '../index.css';

interface Props {
  title?: string;
  description?: string;
  activeTab?: 'home' | 'blog' | 'projects' | 'about';
  /** Sayfanın tam canonical URL'si. Varsayılan: site kökü */
  canonicalUrl?: string;
  /** OG image URL'si. Varsayılan: profil fotoğrafı */
  ogImage?: string;
}

const {
  title = "Nurullah Kartal | Ön Muhasebe & Lojistik Uzmanı",
  description = "Yaklaşık 4 yıldır sahada ön muhasebe, fatura takipleri ve lojistik veri girişleri üzerine çalışan, Atatürk Üniversitesi öğrencisi Nurullah Kartal'ın mesleki blog ve portfolyo sitesi.",
  activeTab = "home",
  canonicalUrl = "https://nurullahkartal.com.tr/",
  ogImage = "https://nurullahkartal.com.tr/images/profil.jpg",
} = Astro.props;

// Navigasyon elemanları
const navItems = [
  { id: 'home', path: '/', label: 'Ana Sayfa' },
  { id: 'blog', path: '/blog', label: 'Mesleki Blog' },
  { id: 'projects', path: '/hobiler', label: 'Hobiler' },
  { id: 'about', path: '/hakkimda', label: 'Hakkımda' }
];

const socialLinks = {
  instagram: "https://www.instagram.com/nurullahkrtal/",
  linkedin: "https://tr.linkedin.com/in/n47kartal",
  email: "mailto:nurullahkartaltr@gmail.com"
};

// JSON-LD için JSON nesnesi oluştur (XSS güvenli)
const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://nurullahkartal.com.tr/#person",
      "name": "Nurullah Kartal",
      "givenName": "Nurullah",
      "familyName": "Kartal",
      "url": "https://nurullahkartal.com.tr",
      "image": {
        "@type": "ImageObject",
        "url": "https://nurullahkartal.com.tr/images/profil.jpg",
        "caption": "Nurullah Kartal - Ön Muhasebe & Lojistik Uzmanı"
      },
      "jobTitle": [
        "Ön Muhasebe Uzmanı",
        "Lojistik Operasyon Uzmanı",
        "Yazılım Geliştirici (Hobi)"
      ],
      "description": "Yaklaşık 4 yıldır sahada ön muhasebe, fatura takipleri ve lojistik veri girişleri üzerine çalışan uzman. Mikro, Logo ve Nes Portal ERP sistemlerinde deneyimli.",
      "knowsAbout": [
        "Ön Muhasebe", "Fatura Takibi", "Lojistik Veri Girişi",
        "E-Fatura ve E-Arşiv", "Muhasebe ve Vergi Uygulamaları",
        "Uluslararası Ticaret ve Lojistik", "Mikro ERP", "Logo ERP",
        "Nes Portal", "Microsoft Excel", "Yazılım ve Web Geliştirme (Hobi)"
      ],
      "alumniOf": [
        {
          "@type": "CollegeOrUniversity",
          "name": "Atatürk Üniversitesi",
          "department": "Muhasebe ve Vergi Uygulamaları"
        },
        {
          "@type": "CollegeOrUniversity",
          "name": "Anadolu Üniversitesi",
          "department": "Uluslararası Ticaret ve Lojistik"
        }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Gaziantep",
        "addressCountry": "TR"
      },
      "nationality": { "@type": "Country", "name": "Türkiye" },
      "sameAs": [
        "https://tr.linkedin.com/in/n47kartal",
        "https://www.instagram.com/nurullahkrtal/",
        "https://github.com/nurullahkartal"
      ],
      "worksFor": {
        "@type": "Organization",
        "@id": "https://nurullahkartal.com.tr/#organization"
      },
      "brand": {
        "@type": "Organization",
        "@id": "https://nurullahkartal.com.tr/#organization"
      }
    },
    {
      "@type": "Organization",
      "@id": "https://nurullahkartal.com.tr/#organization",
      "name": "NK YAZILIM",
      "alternateName": "NK Yazılım",
      "url": "https://nurullahkartal.com.tr",
      "logo": {
        "@type": "ImageObject",
        "url": "https://nurullahkartal.com.tr/images/nk-logo.png",
        "caption": "NK YAZILIM Logosu"
      },
      "founder": {
        "@type": "Person",
        "@id": "https://nurullahkartal.com.tr/#person"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "email": "nurullahkartaltr@gmail.com",
        "availableLanguage": ["Turkish"]
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://nurullahkartal.com.tr/#website",
      "url": "https://nurullahkartal.com.tr",
      "name": "Nurullah Kartal",
      "description": "Nurullah Kartal'ın kişisel mesleki blog ve portfolyo sitesi. Ön muhasebe, lojistik ve dijital gelişim üzerine pratik içerikler.",
      "inLanguage": "tr-TR",
      "publisher": { "@id": "https://nurullahkartal.com.tr/#organization" },
      "author": { "@id": "https://nurullahkartal.com.tr/#person" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://nurullahkartal.com.tr/blog?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "WebPage",
      "@id": `${canonicalUrl}#webpage`,
      "url": canonicalUrl,
      "name": title,
      "description": description,
      "inLanguage": "tr-TR",
      "isPartOf": { "@id": "https://nurullahkartal.com.tr/#website" },
      "about": { "@id": "https://nurullahkartal.com.tr/#person" }
    }
  ]
};

const schemaJson = JSON.stringify(schemaGraph);
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/images/nk-logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Temel SEO Meta Etiketleri -->
    <meta name="description" content={description} />
    <meta name="keywords" content="Nurullah Kartal, ön muhasebe uzmanı, fatura takibi, lojistik veri girişi, e-fatura, e-arşiv, Mikro ERP, Logo ERP, Atatürk Üniversitesi, muhasebe blogu, NK Yazılım, Gaziantep muhasebe" />
    <meta name="author" content="Nurullah Kartal" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#4f46e5" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nurullah Kartal" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Nurullah Kartal - Ön Muhasebe & Lojistik Uzmanı" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Kombine Master JSON-LD Schema -->
    <script type="application/ld+json" set:html={schemaJson} />

    <!-- Sayfaya özgü ek head içeriği (BlogPosting şeması vb.) -->
    <slot name="head" />

    <!-- Dark Mode Inline Script -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('theme');
          if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        } catch (e) {
          console.warn('localStorage is not available:', e);
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 selection:bg-indigo-500 selection:text-white antialiased transition-colors duration-200 flex flex-col overflow-x-hidden">

    <!-- HEADER / NAVIGATION -->
    <header class="sticky top-0 z-50 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 transition-colors duration-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-2">

        <!-- Logo -->
        <a
          href="/"
          class="flex items-center gap-2 hover:opacity-90 transition-opacity flex-shrink-0"
          aria-label="Nurullah Kartal - Ana Sayfa"
        >
          <img
            src="/images/nk-logo.png"
            alt="NK YAZILIM - Nurullah Kartal Logo"
            class="h-8 w-auto object-contain dark:brightness-110"
            width="32"
            height="32"
          />
          <span class="text-base font-bold tracking-tight text-indigo-600 dark:text-indigo-400 hidden xs:block sm:block">
            Nurullah KARTAL
          </span>
        </a>

        <!-- Desktop Nav (md ve üstü) -->
        <nav class="hidden md:flex items-center space-x-1" aria-label="Ana Navigasyon">
          {navItems.map((item) => (
            <a
              href={item.path}
              class={`px-3 py-1.5 text-sm font-medium rounded-md transition-colors ${
                activeTab === item.id
                  ? 'bg-indigo-50 dark:bg-indigo-950/50 text-indigo-600 dark:text-indigo-400'
                  : 'text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800'
              }`}
              aria-current={activeTab === item.id ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Sağ taraf: Dark mode + Hamburger -->
        <div class="flex items-center gap-2">
          <!-- Dark Mode Toggle -->
          <button
            id="theme-toggle"
            class="p-2 rounded-md hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors cursor-pointer border border-slate-200/50 dark:border-slate-700/50 text-base leading-none"
            aria-label="Tema Değiştir"
          >
            <span id="theme-toggle-icon">🌙</span>
          </button>

          <!-- Hamburger (yalnızca md altında görünür) -->
          <button
            id="mobile-menu-btn"
            class="md:hidden flex flex-col justify-center items-center w-9 h-9 rounded-md hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors border border-slate-200/50 dark:border-slate-700/50 gap-1.5 cursor-pointer"
            aria-label="Menüyü Aç/Kapat"
            aria-expanded="false"
          >
            <span class="hamburger-bar block w-5 h-0.5 bg-slate-700 dark:bg-slate-300 rounded transition-all duration-300"></span>
            <span class="hamburger-bar block w-5 h-0.5 bg-slate-700 dark:bg-slate-300 rounded transition-all duration-300"></span>
            <span class="hamburger-bar block w-5 h-0.5 bg-slate-700 dark:bg-slate-300 rounded transition-all duration-300"></span>
          </button>
        </div>
      </div>

      <!-- Mobil Menü Açılır Paneli -->
      <div
        id="mobile-menu"
        class="md:hidden hidden border-t border-slate-200 dark:border-slate-800 bg-white/95 dark:bg-slate-900/95 backdrop-blur-md"
        aria-label="Mobil Navigasyon"
      >
        <nav class="max-w-5xl mx-auto px-4 py-3 flex flex-col gap-1">
          {navItems.map((item) => (
            <a
              href={item.path}
              class={`px-4 py-3 text-sm font-semibold rounded-xl transition-colors flex items-center gap-2 ${
                activeTab === item.id
                  ? 'bg-indigo-50 dark:bg-indigo-950/50 text-indigo-600 dark:text-indigo-400'
                  : 'text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800'
              }`}
              aria-current={activeTab === item.id ? 'page' : undefined}
            >
              {activeTab === item.id && <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 flex-shrink-0"></span>}
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <!-- MAIN CONTENT AREA -->
    <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-12 flex-grow w-full">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 transition-colors duration-200" aria-label="Site Alt Bilgisi">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4 sm:h-14 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-slate-500 dark:text-slate-400">
        <div class="text-center sm:text-left">© 2026 Nurullah Kartal — NK YAZILIM. Tüm hakları saklıdır.</div>
        <div class="flex gap-4">
          <a href={socialLinks.linkedin} target="_blank" rel="noreferrer noopener" class="hover:underline hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">LinkedIn</a>
          <a href={socialLinks.instagram} target="_blank" rel="noreferrer noopener" class="hover:underline hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Instagram</a>
        </div>
      </div>
    </footer>

    <!-- Tema ve Hamburger Menü Script'leri -->
    <script>
      // ---- Tema Toggle ----
      const themeToggle = document.getElementById('theme-toggle');
      const themeToggleIcon = document.getElementById('theme-toggle-icon');

      function updateThemeButton(theme: string) {
        if (themeToggleIcon) {
          themeToggleIcon.textContent = theme === 'light' ? '🌙' : '☀️';
        }
      }

      const currentTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
      updateThemeButton(currentTheme);

      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          const newTheme = isDark ? 'dark' : 'light';
          localStorage.setItem('theme', newTheme);
          updateThemeButton(newTheme);
        });
      }

      // ---- Hamburger Menü Toggle ----
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerBars = document.querySelectorAll('.hamburger-bar');

      function toggleMobileMenu(open: boolean) {
        if (!mobileMenu || !mobileMenuBtn) return;
        if (open) {
          mobileMenu.classList.remove('hidden');
          mobileMenuBtn.setAttribute('aria-expanded', 'true');
          // X animasyonu
          if (hamburgerBars[0]) (hamburgerBars[0] as HTMLElement).style.transform = 'translateY(8px) rotate(45deg)';
          if (hamburgerBars[1]) (hamburgerBars[1] as HTMLElement).style.opacity = '0';
          if (hamburgerBars[2]) (hamburgerBars[2] as HTMLElement).style.transform = 'translateY(-8px) rotate(-45deg)';
        } else {
          mobileMenu.classList.add('hidden');
          mobileMenuBtn.setAttribute('aria-expanded', 'false');
          if (hamburgerBars[0]) (hamburgerBars[0] as HTMLElement).style.transform = '';
          if (hamburgerBars[1]) (hamburgerBars[1] as HTMLElement).style.opacity = '';
          if (hamburgerBars[2]) (hamburgerBars[2] as HTMLElement).style.transform = '';
        }
      }

      let menuOpen = false;
      if (mobileMenuBtn) {
        mobileMenuBtn.addEventListener('click', () => {
          menuOpen = !menuOpen;
          toggleMobileMenu(menuOpen);
        });
      }

      // Menü dışına tıklanınca kapat
      document.addEventListener('click', (e) => {
        if (menuOpen && mobileMenu && mobileMenuBtn) {
          if (!mobileMenu.contains(e.target as Node) && !mobileMenuBtn.contains(e.target as Node)) {
            menuOpen = false;
            toggleMobileMenu(false);
          }
        }
      });

      // Pencere genişletilince mobil menüyü kapat
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768 && menuOpen) {
          menuOpen = false;
          toggleMobileMenu(false);
        }
      });
    </script>
  </body>
</html>
