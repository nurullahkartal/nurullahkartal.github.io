---
import Layout from '../layouts/Layout.astro';
import { projects, webTools } from '../data/siteData';
---

<Layout title="Dijital Gelişim & Hobiler | Nurullah Kartal" activeTab="projects" description="Tamamen hobi amaçlı, kendimi denemek ve dijital süreçleri öğrenmek adına yaptığım çalışmalar." canonicalUrl="https://nurullahkartal.com.tr/hobiler">
  <section class="space-y-10 sm:space-y-12">

    <!-- Sayfa Başlığı -->
    <div class="border-b border-slate-200 dark:border-slate-800 pb-4">
      <h1 class="text-2xl sm:text-3xl font-black tracking-tight text-slate-950 dark:text-white">Dijital Gelişim & Hobiler</h1>
      <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Tamamen hobi amaçlı, kendimi denemek ve dijital süreçleri öğrenmek adına yaptığım çalışmalar.</p>
    </div>

    <!-- Öne Çıkan Dijital Çalışmalar -->
    <div class="space-y-5 sm:space-y-6">
      <h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
        <span class="w-1.5 h-6 bg-indigo-500 rounded-full flex-shrink-0"></span>
        Öne Çıkan Dijital Çalışmalar
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6">
        {projects.map(project => (
          <div class="p-5 sm:p-6 bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl shadow-xs hover:shadow-md hover:border-indigo-500/40 dark:hover:border-indigo-400/40 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between">
            <div class="space-y-3">
              <div class="flex items-center gap-2.5">
                <span class="text-2xl select-none flex-shrink-0">🚀</span>
                <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white tracking-tight">{project.title}</h3>
              </div>
              <p class="text-slate-600 dark:text-slate-350 text-sm leading-relaxed">{project.description}</p>
            </div>
            <div class="mt-5 pt-4 border-t border-slate-100 dark:border-slate-800/60">
              <div class="flex flex-wrap gap-1 mb-4">
                {project.tech.map(t => (
                  <span class="px-2.5 py-0.5 bg-slate-50 dark:bg-slate-950 text-slate-500 dark:text-slate-450 text-xs rounded border border-slate-100 dark:border-slate-850 font-medium">
                    {t}
                  </span>
                ))}
              </div>
              <div class="flex gap-3">
                {project.liveUrl && (
                  <a
                    href={project.liveUrl}
                    target="_blank"
                    rel="noreferrer"
                    class="px-3.5 py-1.5 bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 text-white rounded-lg text-xs font-semibold shadow-xs hover:shadow-sm transition-all"
                  >
                    Canlı Önizleme →
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Web Araçları & Portallar -->
    <div class="space-y-5 sm:space-y-6 pt-4">
      <h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
        <span class="w-1.5 h-6 bg-indigo-500 rounded-full flex-shrink-0"></span>
        Web Araçları & Portallar
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
        {webTools.map(tool => (
          <div class="p-5 sm:p-6 bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl shadow-xs hover:shadow-md hover:border-indigo-500/40 dark:hover:border-indigo-400/40 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between">
            <div class="space-y-3">
              <div class="flex items-center gap-2.5">
                <span class="text-2xl select-none flex-shrink-0">⚡</span>
                <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white tracking-tight">{tool.title}</h3>
              </div>
              <p class="text-slate-600 dark:text-slate-350 text-sm leading-relaxed">{tool.description}</p>
            </div>
            <div class="mt-5 pt-4 border-t border-slate-100 dark:border-slate-800/60">
              <div class="flex flex-wrap gap-1 mb-4">
                {tool.tech.map(t => (
                  <span class="px-2.5 py-0.5 bg-slate-50 dark:bg-slate-950 text-slate-500 dark:text-slate-450 text-xs rounded border border-slate-100 dark:border-slate-850 font-medium">
                    {t}
                  </span>
                ))}
              </div>
              <a
                href={tool.url}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 text-white rounded-lg text-sm font-semibold shadow-xs hover:shadow-sm transition-all cursor-pointer"
              >
                Uygulamayı Başlat ⚡
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>

  </section>
</Layout>
