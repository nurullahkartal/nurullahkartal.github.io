---
import Layout from '../../layouts/Layout.astro';
import BlogEngine from '../../components/BlogEngine';
import { blogPosts } from '../../data/blogData';
---

<Layout title="Mesleki Blog & İpuçları | Nurullah Kartal" activeTab="blog" description="Ön muhasebe, lojistik operasyonlar, ERP entegrasyonları ve Excel verimlilik ipuçları üzerine pratik rehberler ve yazılar." canonicalUrl="https://nurullahkartal.com.tr/blog">
  <section class="space-y-8">
    <div class="border-b border-slate-200 dark:border-slate-800 pb-4">
      <h1 class="text-3xl font-black tracking-tight text-slate-950 dark:text-white">Mesleki Blog & İpuçları</h1>
      <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Ön muhasebe, lojistik operasyonlar, ERP entegrasyonları ve Excel verimlilik ipuçları üzerine pratik rehberler ve yazılar.</p>
    </div>

    <!-- Interactive Blog Island -->
    <BlogEngine client:load initialPosts={blogPosts} />
  </section>
</Layout>
