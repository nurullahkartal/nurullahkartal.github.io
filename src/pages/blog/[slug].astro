---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blogData';

export async function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;

// Sayfaya özgü URL ve tarih değerleri
const pageUrl = `https://nurullahkartal.com.tr/blog/${post.id}`;
const publishDate = post.date || "2026-05-26";

// BlogPosting JSON-LD Şeması (her makaleye özel, dinamik)
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${pageUrl}#blogposting`,
  "headline": post.title,
  "description": post.description,
  "url": pageUrl,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageUrl
  },
  "datePublished": publishDate,
  "dateModified": "2026-05-26",
  "inLanguage": "tr-TR",
  "articleSection": post.category,
  "author": {
    "@type": "Person",
    "@id": "https://nurullahkartal.com.tr/#person",
    "name": "Nurullah Kartal",
    "url": "https://nurullahkartal.com.tr",
    "image": "https://nurullahkartal.com.tr/images/profil.jpg",
    "jobTitle": "Ön Muhasebe & Lojistik Uzmanı"
  },
  "publisher": {
    "@type": "Organization",
    "@id": "https://nurullahkartal.com.tr/#organization",
    "name": "NK YAZILIM",
    "url": "https://nurullahkartal.com.tr",
    "logo": {
      "@type": "ImageObject",
      "url": "https://nurullahkartal.com.tr/images/nk-logo.png"
    }
  },
  "image": {
    "@type": "ImageObject",
    "url": "https://nurullahkartal.com.tr/images/profil.jpg"
  },
  "isPartOf": {
    "@type": "Blog",
    "@id": "https://nurullahkartal.com.tr/blog",
    "name": "Nurullah Kartal Mesleki Blog",
    "publisher": {
      "@id": "https://nurullahkartal.com.tr/#organization"
    }
  }
};

const schemaJson = JSON.stringify(blogPostingSchema);

// Bold ve inline code markdown parser
function parseInlineMarkdown(text: string) {
  // 1. Bold (**text**) parse et
  let parsed = text.split('**').map((part, index) => {
    if (index % 2 === 1) {
      return `<strong class="font-bold text-slate-950 dark:text-white">${part}</strong>`;
    }
    return part;
  }).join('');

  // 2. Inline code (`code`) parse et
  parsed = parsed.split('`').map((part, index) => {
    if (index % 2 === 1) {
      return `<code class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 font-mono rounded text-xs sm:text-sm font-semibold select-all">${part}</code>`;
    }
    return part;
  }).join('');

  return parsed;
}

const lines = post.content.split('\n');
const parsedBlocks = [];
let currentList: string[] = [];
let currentCode: { language: string; lines: string[] } | null = null;

for (let i = 0; i < lines.length; i++) {
  const line = lines[i].trim();

  if (currentCode !== null) {
    if (line.startsWith('```')) {
      parsedBlocks.push({
        type: 'code',
        language: currentCode.language,
        code: currentCode.lines.join('\n'),
        items: [] as string[],
        html: ''
      });
      currentCode = null;
    } else {
      currentCode.lines.push(lines[i]);
    }
    continue;
  }

  if (line.startsWith('```')) {
    const language = line.replace('```', '').trim() || 'EXCEL';
    currentCode = { language, lines: [] };
    if (currentList.length > 0) {
      parsedBlocks.push({ type: 'list', items: currentList, language: '', code: '', html: '' });
      currentList = [];
    }
    continue;
  }

  if (line === '') {
    if (currentList.length > 0) {
      parsedBlocks.push({ type: 'list', items: currentList, language: '', code: '', html: '' });
      currentList = [];
    }
    continue;
  }

  // ### H3 başlıkları — SEO için <h3> (sayfanın H1'i makale başlığı, H2 ise bölüm başlıkları için kullanılır)
  if (line.startsWith('### ')) {
    if (currentList.length > 0) {
      parsedBlocks.push({ type: 'list', items: currentList, language: '', code: '', html: '' });
      currentList = [];
    }
    parsedBlocks.push({
      type: 'h3',
      html: parseInlineMarkdown(line.replace('### ', '')),
      items: [] as string[],
      language: '',
      code: ''
    });
    continue;
  }

  // ## H2 başlıkları — bölüm başlıkları
  if (line.startsWith('## ')) {
    if (currentList.length > 0) {
      parsedBlocks.push({ type: 'list', items: currentList, language: '', code: '', html: '' });
      currentList = [];
    }
    parsedBlocks.push({
      type: 'h2',
      html: parseInlineMarkdown(line.replace('## ', '')),
      items: [] as string[],
      language: '',
      code: ''
    });
    continue;
  }

  if (line.startsWith('📝 ')) {
    if (currentList.length > 0) {
      parsedBlocks.push({ type: 'list', items: currentList, language: '', code: '', html: '' });
      currentList = [];
    }
    parsedBlocks.push({
      type: 'alert',
      html: parseInlineMarkdown(line.replace(/^📝\s*/, '')),
      items: [] as string[],
      language: '',
      code: ''
    });
    continue;
  }

  if (line.startsWith('* ')) {
    currentList.push(parseInlineMarkdown(line.replace(/^\*\s+/, '')));
    continue;
  }

  if (currentList.length > 0) {
    parsedBlocks.push({ type: 'list', items: currentList, language: '', code: '', html: '' });
    currentList = [];
  }
  parsedBlocks.push({
    type: 'paragraph',
    html: parseInlineMarkdown(line),
    items: [] as string[],
    language: '',
    code: ''
  });
}

if (currentList.length > 0) {
  parsedBlocks.push({ type: 'list', items: currentList, language: '', code: '', html: '' });
}
---

<Layout
  title={`${post.title} | Nurullah Kartal`}
  activeTab="blog"
  description={post.description}
  canonicalUrl={pageUrl}
>
  <!-- BlogPosting JSON-LD (makaleye özel dinamik şema) -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schemaJson} />
  </Fragment>

  <div class="max-w-3xl mx-auto animate-fade-in-up">
    <!-- Geri Dönüş Navigasyonu -->
    <div class="mb-6 sm:mb-8">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 px-3 sm:px-4 py-2 text-xs sm:text-sm font-semibold text-slate-600 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 bg-white/80 dark:bg-slate-900/80 hover:bg-indigo-50 dark:hover:bg-indigo-950/30 rounded-xl transition-all duration-300 border border-slate-200/50 dark:border-slate-800/80 hover:-translate-x-1 group shadow-xs"
      >
        <span class="text-base transition-transform duration-300 group-hover:-translate-x-0.5">←</span> Blog Yazılarına Dön
      </a>
    </div>

    <article
      class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl sm:rounded-3xl shadow-xl p-4 sm:p-8 md:p-12 space-y-6 sm:space-y-8"
      itemscope
      itemtype="https://schema.org/BlogPosting"
    >
      <!-- Makale Üst Bilgi Başlığı -->
      <header class="border-b border-slate-100 dark:border-slate-800/60 pb-6 space-y-4">
        <div class="flex items-center gap-3">
          <span class="px-3 py-1 bg-indigo-50 dark:bg-indigo-950/45 text-indigo-600 dark:text-indigo-400 text-xs font-bold rounded-lg uppercase tracking-wider" itemprop="articleSection">
            {post.category}
          </span>
          <span class="text-slate-400 dark:text-slate-500 text-xs font-semibold tracking-wide">⏱️ {post.readTime}</span>
        </div>
        <!-- H1: Makale başlığı — bu sayfanın tek H1'i -->
        <h1
          class="text-2xl sm:text-3xl md:text-4xl font-black text-slate-950 dark:text-white tracking-tight leading-[1.2]"
          itemprop="headline"
        >
          {post.title}
        </h1>
        <div class="flex items-center justify-between gap-4 pt-2 flex-wrap">
          <div class="flex items-center gap-2.5 text-xs font-semibold text-slate-500 dark:text-slate-450" itemprop="author" itemscope itemtype="https://schema.org/Person">
            <div class="w-7 h-7 rounded-full overflow-hidden border border-slate-200 dark:border-slate-800 shadow-sm flex-shrink-0">
              <img src="/images/profil.jpg" alt="Nurullah Kartal" class="w-full h-full object-cover" width="28" height="28" />
            </div>
            <div>
              <p class="text-slate-800 dark:text-slate-200 font-bold" itemprop="name">{post.author}</p>
              <p class="text-[10px] text-slate-400 mt-0.5">Ön Muhasebe & Lojistik Uzmanı</p>
            </div>
          </div>
          <time
            class="text-slate-400 dark:text-slate-500 text-xs font-bold uppercase tracking-wider"
            datetime={publishDate}
            itemprop="datePublished"
          >
            {post.date}
          </time>
        </div>
      </header>

      <!-- Makale Özeti (description) -->
      {post.description && (
        <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 leading-relaxed font-medium bg-slate-50 dark:bg-slate-800/50 rounded-xl px-5 py-4 border border-slate-100 dark:border-slate-800/60" itemprop="description">
          {post.description}
        </p>
      )}

      <!-- Makale İçeriği (Dinamik Server-Side Renderer) -->
      <div class="text-slate-700 dark:text-slate-300 text-[16px] leading-[1.85] space-y-6" itemprop="articleBody">
        {parsedBlocks.map((block) => {
          if (block.type === 'alert') {
            return (
              <div class="flex gap-4 p-5 bg-indigo-50/30 dark:bg-indigo-950/15 border-l-4 border-indigo-500 rounded-r-2xl my-6 text-[15px] text-slate-800 dark:text-slate-200 leading-[1.8] font-medium shadow-2xs">
                <span class="text-2xl select-none flex-shrink-0">📝</span>
                <div set:html={block.html} />
              </div>
            );
          }
          // H2 bölüm başlığı (### içeriğinin üst kategorisi için ##)
          if (block.type === 'h2') {
            return (
              <h2 class="text-xl sm:text-2xl font-bold text-slate-950 dark:text-white mt-8 sm:mt-12 mb-4 sm:mb-5 border-b border-slate-100 dark:border-slate-800/80 pb-2 sm:pb-3 tracking-tight" set:html={block.html} />
            );
          }
          // H3 alt başlık (### ile işaretlenmiş başlıklar)
          if (block.type === 'h3') {
            return (
              <h3 class="text-lg sm:text-xl font-bold text-slate-950 dark:text-white mt-7 sm:mt-10 mb-3 sm:mb-4 border-b border-slate-100 dark:border-slate-800/80 pb-2 sm:pb-3 tracking-tight" set:html={block.html} />
            );
          }
          if (block.type === 'list') {
            return (
              <ul class="list-none pl-2 my-5 space-y-2.5">
                {block.items.map((item) => (
                  <li class="flex items-start gap-2.5 text-slate-700 dark:text-slate-350 text-[16px] leading-[1.8] my-2">
                    <span class="text-indigo-500 mt-1.5 flex-shrink-0 text-[10px] select-none">◆</span>
                    <span set:html={item} />
                  </li>
                ))}
              </ul>
            );
          }
          if (block.type === 'code') {
            return (
              <div class="relative group my-4 sm:my-6 rounded-xl sm:rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800/60 shadow-md">
                <div class="bg-slate-100 dark:bg-slate-900/90 px-3 sm:px-4 py-2 sm:py-2.5 text-xs text-slate-500 dark:text-slate-400 font-mono border-b border-slate-200 dark:border-slate-800/80 flex justify-between items-center select-none">
                  <div class="flex items-center gap-1.5 min-w-0">
                    <span class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-red-400 dark:bg-red-500/40 inline-block flex-shrink-0"></span>
                    <span class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-amber-400 dark:bg-amber-500/40 inline-block flex-shrink-0"></span>
                    <span class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-emerald-400 dark:bg-emerald-500/40 inline-block flex-shrink-0"></span>
                    <span class="ml-2 font-semibold text-[10px] sm:text-[11px] tracking-wider text-slate-600 dark:text-slate-400 truncate">{(block.language || '').toUpperCase()} FORMÜLÜ</span>
                  </div>
                  <button
                    class="copy-formula-btn flex-shrink-0 ml-2 px-2 sm:px-2.5 py-1 text-slate-600 dark:text-slate-300 hover:text-white dark:hover:text-white hover:bg-indigo-600 dark:hover:bg-indigo-600 rounded-lg transition-all duration-200 cursor-pointer font-bold text-[10px] bg-slate-200/50 dark:bg-slate-800/50 border border-slate-300/30 dark:border-slate-700/50 shadow-2xs"
                    data-code={block.code}
                    aria-label="Formülü kopyala"
                  >
                    Kopyala 📋
                  </button>
                </div>
                {/* overflow-x-auto: mobilde uzun formüller sayfayı yatay kaydırmaz, sadece kutu içinde kayar */}
                <pre class="p-3 sm:p-5 bg-slate-950 text-emerald-400 dark:bg-slate-950 font-mono text-[12px] sm:text-[13px] overflow-x-auto leading-relaxed"><code>{block.code}</code></pre>
              </div>
            );
          }
          return (
            <p class="text-slate-700 dark:text-slate-300 text-[16px] leading-[1.85] my-4 text-justify sm:text-left" set:html={block.html} />
          );
        })}
      </div>

      <!-- Alt Kısım: Yazar Kartı ve Geri Dönüş -->
      <footer class="mt-12 pt-8 border-t border-slate-100 dark:border-slate-800/60 space-y-6">
        <!-- Yazar Bilgisi Kartı -->
        <div class="flex items-center gap-4 p-4 bg-slate-50 dark:bg-slate-800/40 rounded-2xl border border-slate-100 dark:border-slate-800/60">
          <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-indigo-200 dark:border-indigo-900 shadow-sm flex-shrink-0">
            <img src="/images/profil.jpg" alt="Nurullah Kartal" class="w-full h-full object-cover" width="48" height="48" />
          </div>
          <div class="flex-grow">
            <p class="font-bold text-slate-950 dark:text-white text-sm">Nurullah Kartal</p>
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Ön Muhasebe & Lojistik Uzmanı · NK YAZILIM</p>
          </div>
          <a
            href="https://tr.linkedin.com/in/n47kartal"
            target="_blank"
            rel="noreferrer noopener"
            class="px-3 py-1.5 text-xs font-semibold text-indigo-600 dark:text-indigo-400 border border-indigo-200 dark:border-indigo-900/60 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-950/30 transition-colors"
          >
            LinkedIn
          </a>
        </div>

        <div class="flex justify-between items-center flex-wrap gap-4">
          <span class="text-xs text-slate-400 dark:text-slate-500 font-semibold uppercase">© 2026 Nurullah Kartal · NK YAZILIM</span>
          <a
            href="/blog"
            class="px-5 py-2.5 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-xs font-bold rounded-xl transition-all inline-block shadow-2xs border border-slate-200/40 dark:border-slate-700/50"
          >
            Tüm Yazılara Geri Dön
          </a>
        </div>
      </footer>
    </article>
  </div>
</Layout>

<!-- Client-side script: formül kopyalama -->
<script>
  const copyButtons = document.querySelectorAll('.copy-formula-btn');
  copyButtons.forEach(button => {
    button.addEventListener('click', () => {
      const code = button.getAttribute('data-code');
      const originalText = button.textContent;
      if (code) {
        navigator.clipboard.writeText(code).then(() => {
          button.textContent = 'Kopyalandı! ✓';
          button.classList.add('bg-emerald-600', 'text-white');
          setTimeout(() => {
            button.textContent = originalText;
            button.classList.remove('bg-emerald-600', 'text-white');
          }, 2000);
        }).catch(err => {
          console.error('Kopyalama hatası:', err);
        });
      }
    });
  });
</script>
