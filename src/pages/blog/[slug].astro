---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blogData';

export async function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;

// Bold text parser helper
function parseBold(text: string) {
  return text.split('**').map((part, index) => {
    if (index % 2 === 1) {
      return `<strong class="font-bold text-slate-950 dark:text-white">${part}</strong>`;
    }
    return part;
  }).join('');
}

const blocks = post.content.split('\n\n');
const parsedBlocks = blocks.map((block) => {
  if (block.startsWith('📝 ')) {
    return {
      type: 'alert',
      html: parseBold(block)
    };
  }
  if (block.startsWith('### ')) {
    return {
      type: 'heading',
      html: block.replace('### ', '')
    };
  }
  if (block.startsWith('* ')) {
    const items = block.split('\n').map(item => {
      const cleanItem = item.replace(/^\*\s+/, '');
      return `<li class="my-1.5">${parseBold(cleanItem)}</li>`;
    }).join('');
    return {
      type: 'list',
      html: `<ul class="list-disc list-outside pl-5 space-y-1 my-4 text-sm text-slate-700 dark:text-slate-350 leading-relaxed">${items}</ul>`
    };
  }
  if (block.includes('```')) {
    const lines = block.split('\n');
    const language = lines[0].replace('```', '').trim() || 'EXCEL';
    const code = lines.slice(1, -1).join('\n');
    return {
      type: 'code',
      language,
      code,
      html: code
    };
  }
  return {
    type: 'paragraph',
    html: parseBold(block)
  };
});
---

<Layout title={`${post.title} | Nurullah Kartal`} activeTab="blog" description={post.description}>
  <div class="max-w-2xl mx-auto bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-3xl shadow-2xl p-6 sm:p-8 animate-fade-in-up">
    <!-- Geri Dönüş ve Üst Bilgi Barı -->
    <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800/60 pb-4 mb-6">
      <div class="flex items-center gap-3">
        <span class="px-2.5 py-0.5 bg-indigo-50 dark:bg-indigo-950/45 text-indigo-600 dark:text-indigo-400 text-xs font-bold rounded">
          {post.category}
        </span>
        <span class="text-slate-400 dark:text-slate-500 text-xs font-semibold">⏱️ {post.readTime}</span>
      </div>
      <a 
        href="/blog"
        class="w-8 h-8 rounded-full bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 flex items-center justify-center text-slate-500 hover:text-slate-800 dark:hover:text-white transition-colors text-sm font-bold"
        aria-label="Blog Listesine Dön"
      >
        ✕
      </a>
    </div>

    <!-- Makale Başlık & Bilgi -->
    <div class="space-y-3 mb-6">
      <span class="text-slate-400 dark:text-slate-500 text-xs font-bold uppercase tracking-wider">{post.date}</span>
      <h1 class="text-2xl sm:text-3xl font-black text-slate-950 dark:text-white tracking-tight leading-tight">
        {post.title}
      </h1>
      <div class="flex items-center gap-2 pt-1.5 text-xs font-semibold text-slate-500 dark:text-slate-400">
        <div class="w-6 h-6 rounded-full bg-indigo-100 dark:bg-indigo-950/40 text-indigo-600 dark:text-indigo-400 flex items-center justify-center font-bold text-[10px]">NK</div>
        <span>Yazar: <strong>{post.author}</strong></span>
      </div>
    </div>

    <!-- Makale İçeriği (Dinamik Server-Side Renderer) -->
    <div class="text-slate-750 dark:text-slate-300 text-sm leading-relaxed space-y-4">
      {parsedBlocks.map((block) => {
        if (block.type === 'alert') {
          return (
            <div class="p-4 bg-indigo-50/50 dark:bg-indigo-950/20 border-l-4 border-indigo-500 rounded-r-xl my-5 text-sm text-indigo-900 dark:text-indigo-300 leading-relaxed font-medium" set:html={block.html} />
          );
        }
        if (block.type === 'heading') {
          return (
            <h3 class="text-lg sm:text-xl font-bold text-slate-950 dark:text-white mt-8 mb-4 border-b border-slate-100 dark:border-slate-800/80 pb-2" set:html={block.html} />
          );
        }
        if (block.type === 'list') {
          return (
            <div set:html={block.html} />
          );
        }
        if (block.type === 'code') {
          return (
            <div class="relative group my-5 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800/80 shadow-xs">
              <div class="bg-slate-100 dark:bg-slate-950 px-4 py-1.5 text-xs text-slate-400 font-mono border-b border-slate-200 dark:border-slate-800/80 flex justify-between items-center select-none">
                <span>{(block.language || '').toUpperCase()}</span>
                <button
                  class="copy-formula-btn px-2 py-0.5 hover:text-white hover:bg-indigo-600 rounded transition-colors cursor-pointer font-bold text-[10px]"
                  data-code={block.code}
                >
                  Kopyala
                </button>
              </div>
              <pre class="p-4 bg-slate-950 text-emerald-400 dark:bg-slate-950 font-mono text-xs overflow-x-auto leading-relaxed"><code>{block.code}</code></pre>
            </div>
          );
        }
        return (
          <p class="text-slate-700 dark:text-slate-350 text-sm leading-relaxed my-3" set:html={block.html} />
        );
      })}
    </div>

    <!-- Geri Dönüş Linki -->
    <div class="mt-8 pt-6 border-t border-slate-100 dark:border-slate-800/60 flex justify-end">
      <a 
        href="/blog"
        class="px-5 py-2.5 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-xs font-bold rounded-xl transition-all inline-block"
      >
        Blog Listesine Geri Dön
      </a>
    </div>
  </div>
</Layout>

<!-- Client-side script for direct clipboard copy operations -->
<script>
  const copyButtons = document.querySelectorAll('.copy-formula-btn');
  copyButtons.forEach(button => {
    button.addEventListener('click', () => {
      const code = button.getAttribute('data-code');
      if (code) {
        navigator.clipboard.writeText(code).then(() => {
          alert('Formül panoya kopyalandı! 📋');
        }).catch(err => {
          console.error('Kopyalama hatası:', err);
        });
      }
    });
  });
</script>
