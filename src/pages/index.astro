---
import Layout from '../layouts/Layout.astro';
import { projects, experiences } from '../data/siteData';

const socialLinks = {
  instagram: "https://www.instagram.com/nurullahkrtal/",
  linkedin: "https://tr.linkedin.com/in/n47kartal",
  email: "mailto:nurullahkartaltr@gmail.com"
};
---

<Layout title="Nurullah Kartal | Muhasebe & Lojistik Uzmanı" activeTab="home">
  <div class="space-y-16">
    <!-- Hero Bölümü -->
    <section class="flex flex-col-reverse md:flex-row items-center justify-between gap-8 md:gap-12 text-center md:text-left py-4">
      <div class="space-y-4 flex-1">
        <h1 class="text-4xl sm:text-5xl font-black text-slate-950 dark:text-white tracking-tight">
          Selam, ben Nurullah. 👋
        </h1>
        
        <!-- Rotating Text Badge Area -->
        <div class="h-9 flex items-center justify-center md:justify-start">
          <span 
            id="rotating-badge"
            class="px-3 py-1 bg-indigo-50 dark:bg-indigo-950/30 text-indigo-600 dark:text-indigo-400 border border-indigo-100/50 dark:border-indigo-900/30 rounded-lg text-sm sm:text-base font-bold tracking-wide uppercase transition-all duration-200"
          >
            Muhasebe Uzmanı
          </span>
        </div>

        <p class="text-lg text-slate-600 dark:text-slate-350 max-w-2xl leading-relaxed mt-4">
          Muhasebe, lojistik ve banka süreçleri üzerine yaklaşık 4 yıllık saha ve ofis deneyimine sahibim. Mikro, Logo ve Nes Portal programlarını aktif kullanarak e-fatura/e-arşiv süreçlerini ve resmi evrak takibini yürüttüm.
        </p>
        
        <!-- Social links row -->
        <div class="flex justify-center md:justify-start gap-4 pt-2">
          <a href={socialLinks.linkedin} target="_blank" rel="noreferrer" class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:underline">LinkedIn</a>
          <a href={socialLinks.instagram} target="_blank" rel="noreferrer" class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:underline">Instagram</a>
          <a href={socialLinks.email} class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:underline">E-Posta</a>
        </div>

        <!-- Primary Call to Actions -->
        <div class="flex flex-wrap justify-center md:justify-start gap-3 pt-4">
          <a 
            href="/hakkimda" 
            class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg shadow-sm hover:shadow-md transition-all inline-block"
          >
            Deneyimlerim
          </a>
          <a 
            href="/hakkimda" 
            class="px-4 py-2 bg-slate-200 hover:bg-slate-300 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-800 dark:text-slate-200 text-sm font-semibold rounded-lg shadow-xs transition-all inline-block"
          >
            Teknik Yetkinlikler
          </a>
          <a 
            href="/hobiler" 
            class="px-4 py-2 bg-slate-200 hover:bg-slate-300 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-800 dark:text-slate-200 text-sm font-semibold rounded-lg shadow-xs transition-all inline-block"
          >
            🚀 Hazır Yazılımlar
          </a>
          <a 
            href="/blog" 
            class="px-4 py-2 bg-indigo-50 hover:bg-indigo-100 dark:bg-indigo-950/40 dark:hover:bg-indigo-950/80 text-indigo-600 dark:text-indigo-400 text-sm font-semibold rounded-lg shadow-xs transition-all border border-indigo-100 dark:border-indigo-900/40 inline-block"
          >
            ✍️ Mesleki Yazılarım
          </a>
          <a 
            href="/files/nurullah_kartal_cv.pdf" 
            download 
            class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg shadow-sm hover:shadow-md transition-all inline-flex items-center gap-1.5"
          >
            📄 CV'mi İndir
          </a>
        </div>
      </div>

      <!-- Avatar Visual Area -->
      <div class="flex-shrink-0">
        <div class="relative group">
          <div class="absolute -inset-1.5 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full blur-sm opacity-30 group-hover:opacity-60 transition duration-500"></div>
          <div class="relative w-40 h-40 sm:w-48 sm:h-48 rounded-full overflow-hidden border-4 border-white dark:border-slate-900 bg-slate-100 dark:bg-slate-800 shadow-md group-hover:scale-102 transition duration-300">
            <img 
              src="/images/profil.jpg" 
              alt="Nurullah Kartal - Ön Muhasebe, Lojistik ve Banka Operasyonları Uzmanı" 
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Hızlı Özet (Quick Facts) Grid -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="p-5 bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl text-center space-y-2 shadow-xs hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
        <div class="text-3xl select-none">🏢</div>
        <h3 class="font-bold text-slate-950 dark:text-white text-sm">Saha Deneyimi</h3>
        <p class="text-xs text-slate-650 dark:text-slate-450 font-medium">4 Yıl Ön Muhasebe & Lojistik Veri Girişi</p>
      </div>
      <div class="p-5 bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl text-center space-y-2 shadow-xs hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
        <div class="text-3xl select-none">🎓</div>
        <h3 class="font-bold text-slate-950 dark:text-white text-sm">Akademik Eğitim</h3>
        <p class="text-xs text-slate-650 dark:text-slate-450 font-medium">Atatürk Üniversitesi & Anadolu Üniversitesi</p>
      </div>
      <div class="p-5 bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl text-center space-y-2 shadow-xs hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
        <div class="text-3xl select-none">💻</div>
        <h3 class="font-bold text-slate-950 dark:text-white text-sm">Uzmanlık & ERP</h3>
        <p class="text-xs text-slate-650 dark:text-slate-450 font-medium">Mikro, Logo, Nes Portal, MS Excel</p>
      </div>
      <div class="p-5 bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl text-center space-y-2 shadow-xs hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
        <div class="text-3xl select-none">📍</div>
        <h3 class="font-bold text-slate-950 dark:text-white text-sm">Lokasyon</h3>
        <p class="text-xs text-slate-650 dark:text-slate-450 font-medium">Gaziantep Merkezli</p>
      </div>
    </section>

    <!-- Öne Çıkan Çalışmalar -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
        <span class="w-1.5 h-6 bg-indigo-500 rounded-full"></span>
        Öne Çıkan Çalışmalar
      </h2>
      <div class="grid sm:grid-cols-1 gap-6">
        {projects.map(project => (
          <div class="p-6 bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl shadow-xs hover:shadow-md hover:border-indigo-500/40 dark:hover:border-indigo-400/40 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between">
            <div class="space-y-3">
              <div class="flex items-center gap-2.5">
                <span class="text-2xl select-none">🚀</span>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white tracking-tight">{project.title}</h3>
              </div>
              <p class="text-slate-600 dark:text-slate-350 text-sm leading-relaxed">{project.description}</p>
            </div>
            <div class="mt-6 pt-4 border-t border-slate-100 dark:border-slate-800/60">
              <div class="flex flex-wrap gap-1 mb-4">
                {project.tech.map(t => (
                  <span class="px-2.5 py-0.5 bg-slate-50 dark:bg-slate-950 text-slate-500 dark:text-slate-450 text-xs rounded border border-slate-100 dark:border-slate-850 font-medium">
                    {t}
                  </span>
                ))}
              </div>
              <div class="flex gap-3 text-xs font-semibold">
                {project.liveUrl && (
                  <a 
                    href={project.liveUrl} 
                    target="_blank" 
                    rel="noreferrer" 
                    class="px-3.5 py-1.5 bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 text-white rounded-lg text-xs font-semibold shadow-xs hover:shadow-sm transition-all"
                  >
                    Canlı Önizleme →
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- İş Deneyimi -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
        <span class="w-1.5 h-6 bg-indigo-500 rounded-full"></span>
        İş Deneyimi
      </h2>
      <div class="space-y-6 relative before:absolute before:left-4 before:top-2 before:bottom-2 before:w-[2px] before:bg-slate-200 dark:before:bg-slate-800">
        {experiences.map(exp => (
          <div class="pl-10 relative group">
            <span class="absolute left-[11px] top-2.5 w-3 h-3 rounded-full bg-indigo-500 border-2 border-white dark:border-slate-950 group-hover:scale-125 transition-transform duration-200"></span>
            <div class="p-5 bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-xl hover:border-slate-350 dark:hover:border-slate-700 transition-colors">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-2">
                <span class="text-xs font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider">{exp.period}</span>
                {exp.companyUrl ? (
                  <a href={exp.companyUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 underline decoration-indigo-500/30">
                    {exp.company}
                  </a>
                ) : (
                  <span class="text-sm font-semibold text-slate-500 dark:text-slate-400">{exp.company}</span>
                )}
              </div>
              <h4 class="text-lg font-bold text-slate-950 dark:text-white">{exp.role}</h4>
              <ul class="list-disc list-outside pl-4 mt-3 text-sm text-slate-600 dark:text-slate-400 space-y-1.5 leading-relaxed">
                {exp.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>

<!-- Client-side script for Hero specialty rotation -->
<script>
  const rotations = ["Muhasebe Uzmanı", "Lojistik Operasyon", "Banka Operasyonları", "e-Fatura / e-Arşiv"];
  let index = 0;
  const badge = document.getElementById('rotating-badge');
  if (badge) {
    setInterval(() => {
      index = (index + 1) % rotations.length;
      badge.classList.add('opacity-0', 'translate-y-2');
      setTimeout(() => {
        badge.textContent = rotations[index];
        badge.classList.remove('opacity-0', 'translate-y-2');
      }, 150);
    }, 3000);
  }
</script>
